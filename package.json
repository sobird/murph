{
  "name": "@sobird/murph",
  "type": "module",
  "version": "1.2.0",
  "description": "A pristine TypeScript template for rapid project inception.",
  "author": "sobird",
  "license": "MIT",
  "keywords": [
    "typescript"
  ],
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run --passWithNoTests --coverage",
    "typecheck": "tsc --noEmit",
    "postinstall": "echo \"postinstall\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-sobird": "^1.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
